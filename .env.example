# Copy to .env and fill in real values. Never commit .env.
# .env is gitignored; .env.example is the onboarding contract.

# ─── LLM providers ────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ─── Google Gemini (M0 anchor-duo TTS: ALEX=Leda, JORDAN=Sadaltager) ──
# GEMINI_API_KEY powers Gemini 2.5 Flash multi-speaker TTS (and later the
# ranking/scripting/verification stages). GEMINI_API_KEY_TTS is an optional
# dedicated TTS-permissioned key; leave empty to fall back to GEMINI_API_KEY.
GEMINI_API_KEY=
GEMINI_API_KEY_TTS=

# ─── SERP image search (poster-seed pipeline) ─────────────
# Serper.dev Google Images API ($1/1k searches). Get a key at https://serper.dev
SERPER_API_KEY=

# ─── Source catalog seeder (scripts/seed_catalog) ─────────
# YouTube Data API v3 key — resolves channel handles → channel id + thumbnail +
# subscriber count (channels.list?forHandle = 1 quota unit/call; 10k/day free).
YOUTUBE_API_KEY=

# ─── YouTube source ingestion anti-throttle (agents/ingestion/adapters/youtube.py)
# Transcript ingestion uses keyless channel RSS + yt-dlp (no Data-API quota). The
# only real wall is YouTube IP-throttling, worst on datacenter (Railway) IPs.
# Cookies make yt-dlp caption fetches look signed-in (defeats the bot-check/429).
# Set ONE of these (cookiefile wins). Leave blank for anonymous (works locally).
YOUTUBE_COOKIEFILE=
YOUTUBE_COOKIES_FROM_BROWSER=
# Self-pacing: jittered delay (seconds) between channels and between videos so a
# burst of polls from one IP does not trip the limiter. 0 = off (local). For cloud
# runs try ~2.0 + ~1.5 jitter.
YOUTUBE_PACE_SECONDS=
YOUTUBE_PACE_JITTER_SECONDS=

# ─── Backend (pick one) ───────────────────────────────────
# Convex
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Supabase — server-side (seed script + migrations; never shipped to the browser).
# Service role key bypasses RLS; keep it secret and out of client bundles.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Supabase — client-side (browser feed queries). Safe to expose: anon key only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional — only needed to apply migrations via `supabase db push`
# (Dashboard → Project Settings → Database → Connection).
SUPABASE_DB_PASSWORD=

# ─── Grounded Q&A worker (Detail interrogation, M2) ───────
# Base origin of the Python worker that serves POST /api/story/{story_id}/question
# (e.g. https://worker.example.com). The static-export Capacitor build has no
# same-origin server, so set this to the deployed worker origin. Leave EMPTY for a
# same-origin relative path (dev rewrite / reverse-proxy fronts the worker).
NEXT_PUBLIC_QA_API_BASE_URL=

# Reel feed source override (Phase 4b SP1). Leave UNSET for production: an authed
# user with a daily_feeds row gets their personalized feed, else the global seeded
# Supabase feed. Set to "fixtures" for a no-network dev loop on the bundled M0 set.
NEXT_PUBLIC_FEED_SOURCE=

# Dev-only onboarding auth bypass. Set to "true" to skip the email/magic-link gate
# and drop straight into the interest picker, with follow-persistence no-op'd (no
# session → no DB writes). For local UI walkthroughs before auth is configured.
# Inlined at build time (a build is required to flip it). Leave UNSET in production.
NEXT_PUBLIC_ONBOARDING_SKIP_AUTH=

# Test-only auth bypass. Set to "true" to swap the email/magic-link gate for a
# fixed-password sign-in: enter ANY email + the code "123456" to create/reuse a
# REAL Supabase session (keeps auth.uid()/RLS intact) — lets you onboard many
# throwaway profiles without the 2/hour mailer cap. REQUIRES the Supabase project
# to have Email "Confirm email" turned OFF. Inlined at build time. Leave UNSET in
# production (cutover: re-enable Confirm email + purge test users).
NEXT_PUBLIC_AUTH_TEST_MODE=

# ─── Payments ─────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Background jobs ──────────────────────────────────────
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_ID=
# Master kill-switch for the Trigger.dev feed crons (daily-personalized-feed,
# feed-readiness-check). They run ONLY when this is exactly "true"; any other
# value (or unset) makes both tasks log a skip and early-return. Reversible.
PIPELINE_CRON_ENABLED=false

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
