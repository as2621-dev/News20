# Copy to .env and fill in real values. Never commit .env.
# .env is gitignored; .env.example is the onboarding contract.

# ─── LLM providers ────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ─── Google Gemini (M0 anchor-duo TTS: ALEX=Leda, JORDAN=Sadaltager) ──
# GEMINI_API_KEY powers Gemini 2.5 Flash multi-speaker TTS (and later the
# ranking/scripting/verification stages). GEMINI_API_KEY_TTS is an optional
# dedicated TTS-permissioned key; leave empty to fall back to GEMINI_API_KEY.
GEMINI_API_KEY=
GEMINI_API_KEY_TTS=

# ─── SERP image search (poster-seed pipeline) ─────────────
# Serper.dev Google Images API ($1/1k searches). Get a key at https://serper.dev
SERPER_API_KEY=

# ─── Backend (pick one) ───────────────────────────────────
# Convex
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Supabase — server-side (seed script + migrations; never shipped to the browser).
# Service role key bypasses RLS; keep it secret and out of client bundles.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Supabase — client-side (browser feed queries). Safe to expose: anon key only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional — only needed to apply migrations via `supabase db push`
# (Dashboard → Project Settings → Database → Connection).
SUPABASE_DB_PASSWORD=

# ─── Grounded Q&A worker (Detail interrogation, M2) ───────
# Base origin of the Python worker that serves POST /api/story/{story_id}/question
# (e.g. https://worker.example.com). The static-export Capacitor build has no
# same-origin server, so set this to the deployed worker origin. Leave EMPTY for a
# same-origin relative path (dev rewrite / reverse-proxy fronts the worker).
NEXT_PUBLIC_QA_API_BASE_URL=

# ─── Payments ─────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Background jobs ──────────────────────────────────────
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_ID=

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
