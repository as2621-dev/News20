          "digest_audio_url": "https://cerfennlcgureyifraqy.supabase.co/storage/v1/object/public/digest-audio/digest-2.mp3",
          "caption_sentences": [
            {
              "sentence_text": "Travis Kelce is now part-owner of a baseball team.",
