    {
      "story_id": "s3",
      "story_headline": "Houston physicists break a 30-year superconductivity record",
      "story_dek": "A team reaches 151 Kelvin at normal pressure — the highest ever recorded.",
      "story_segment_slug": "tech",
      "story_primary_outlet_name": "ScienceDaily",
      "story_first_reported_utc": "2026-05-30T23:42:17.210439+00:00",
      "segments": {
        "segment_label": "Tech & Science"
      },
      "digests": [
        {
          "digest_id": "7dbac3d3-e8ad-4f53-b15c-cecd011f9fb3",
          "digest_audio_url": "https://cerfennlcgureyifraqy.supabase.co/storage/v1/object/public/digest-audio/digest-3.mp3",
          "caption_sentences": [
            {
              "sentence_text": "Physicists in Houston just broke a record that stood for more than thirty years.",
              "anchor_speaker": "ALEX",
              "sentence_index": 0
            },
            {
              "sentence_text": "We're talking superconductivity — materials that carry electricity with zero resistance, no energy lost at all.",
              "anchor_speaker": "JORDAN",
              "sentence_index": 1
            },
            {
              "sentence_text": "The catch has always been the cold.",
              "anchor_speaker": "ALEX",
              "sentence_index": 2
            },
            {
              "sentence_text": "You needed extreme temperatures to make it work.",
              "anchor_speaker": "JORDAN",
              "sentence_index": 3
            },
            {
              "sentence_text": "The old record, set back in 1993, was 133 Kelvin.",
              "anchor_speaker": "ALEX",
              "sentence_index": 4
            },
            {
              "sentence_text": "The University of Houston team just pushed that to 151 Kelvin — the highest ever at normal, everyday pressure.",
              "anchor_speaker": "JORDAN",
              "sentence_index": 5
            },
            {
              "sentence_text": "They used a trick called \"pressure quenching\" — squeeze the material, then lock in the new properties after the pressure is gone.",
              "anchor_speaker": "ALEX",
              "sentence_index": 6
            },
            {
              "sentence_text": "It's still really cold, about minus 122 Celsius — but every degree closer to room temperature matters.",
              "anchor_speaker": "JORDAN",
              "sentence_index": 7
            },
            {
              "sentence_text": "Because if we ever get there: lossless power grids, faster electronics, better fusion and medical scanners.",
              "anchor_speaker": "ALEX",
              "sentence_index": 8
            },
            {
              "sentence_text": "A thirty-year wall, finally moved.",
              "anchor_speaker": "JORDAN",
              "sentence_index": 9
            }
          ],
          "digest_is_current": true,
          "digest_duration_ms": 55891,
          "digest_ambient_poster_url": "https://cerfennlcgureyifraqy.supabase.co/storage/v1/object/public/story-posters/digest-3.png"
        }
      ]
    },
