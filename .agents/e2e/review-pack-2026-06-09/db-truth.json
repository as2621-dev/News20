      "story_id": "s4",
      "story_headline": "Nvidia’s blowout quarter — yet the stock slips",
      "story_dek": "Data-center revenue nearly doubles, but a stock priced for perfection dips anyway.",
      "story_segment_slug": "markets",
      "story_primary_outlet_name": "CNBC",
      "story_first_reported_utc": "2026-05-30T23:42:19.125348+00:00",
      "segments": {
        "segment_label": "Markets"
      },
      "digests": [
        {
          "digest_id": "868c962d-f506-4bfa-81fc-32d459fece63",
          "digest_audio_url": "https://cerfennlcgureyifraqy.supabase.co/storage/v1/object/public/digest-audio/digest-4.mp3",
          "caption_sentences": [
            {
              "sentence_text": "Nvidia just reported earnings — and the AI boom shows no sign of cooling.",
              "anchor_speaker": "JORDAN",
              "sentence_index": 0
            },
            {
              "sentence_text": "The chipmaker pulled in 81.6 billion dollars in revenue for the quarter.",
              "anchor_speaker": "ALEX",
              "sentence_index": 1
            },
            {
              "sentence_text": "Wall Street had expected about 79.",
              "anchor_speaker": "JORDAN",
              "sentence_index": 2
            },
            {
              "sentence_text": "The engine is the data-center business — revenue there nearly doubled from a year ago.",
              "anchor_speaker": "ALEX",
              "sentence_index": 3
            },
            {
              "sentence_text": "That's the AI gold rush in a single number.",
              "anchor_speaker": "JORDAN",
